# Public CRM URL for one-off setup scripts (e.g. https://newlegacyai.ca)
CRM_PUBLIC_URL=
CALENDLY_API_TOKEN=
RESEND_API_KEY=

# Apify – for Lead Scraper (Google Maps with contact details actor)
APIFY_TOKEN=

# Meta (Facebook) Ads – for Ads page sync (ads_management, ads_read, read_insights)
META_ADS_ACCESS_TOKEN=
